<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Anchor.Mobile.Views.HomePage"
             Title="Anchor">
    <VerticalStackLayout Padding="24" Spacing="14">
        <Label Text="Anchor — companion" FontSize="28" FontAttributes="Bold" />
        <Label Text="This device is your executive-function external scaffold. Keep it within reach." />
        <Button Text="Pair with desktop" Clicked="OnPair" />
        <Button Text="Register anchor objects" Clicked="OnRegister" />
        <Label x:Name="StatusLabel" TextColor="Gray" Margin="0,12,0,0" />
    </VerticalStackLayout>
</ContentPage>